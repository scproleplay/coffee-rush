{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    }
  ],
  "redirects": [
    { "source": "/coffee-rush.html", "destination": "/coffee-rush/", "permanent": true },
    { "source": "/reaction-timer.html", "destination": "/reaction-timer/", "permanent": true },
    { "source": "/memory-match.html", "destination": "/memory-match/", "permanent": true },
    { "source": "/math-rush.html", "destination": "/math-rush/", "permanent": true },
    { "source": "/coffee-escape.html", "destination": "/coffee-escape/", "permanent": true },
    { "source": "/leaderboard.html", "destination": "/leaderboard/", "permanent": true }
  ],
  "rewrites": [
    { "source": "/coffee-escape", "destination": "/coffee-escape/index.html" },
    { "source": "/coffee-rush", "destination": "/coffee-rush/index.html" },
    { "source": "/reaction-timer", "destination": "/reaction-timer/index.html" },
    { "source": "/memory-match", "destination": "/memory-match/index.html" },
    { "source": "/math-rush", "destination": "/math-rush/index.html" },
    { "source": "/leaderboard", "destination": "/leaderboard/index.html" },
    { "source": "/profile", "destination": "/profile/index.html" },
    { "source": "/admin", "destination": "/admin/index.html" }
  ]
}
